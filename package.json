/* ===== MAIN CONTAINER ===== */
.app-wrapper {
  min-height: 100vh;
  background-color: #eef2f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50px 20px;
}

/* ===== CARD ===== */
.card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 35px 30px;
  width: 100%;
  max-width: 460px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

/* ===== HEADER ===== */
.app-title {
  font-size: 26px;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 6px;
}

.app-subtitle {
  font-size: 13px;
  color: #7f8c8d;
  margin-bottom: 24px;
}

/* ===== INPUT ROW ===== */
.input-row {
  display: flex;
  gap: 10px;
  margin-bottom: 24px;
}

.task-input {
  flex: 1;
  padding: 10px 14px;
  font-size: 14px;
  border: 1.5px solid #cdd5e0;
  border-radius: 8px;
  outline: none;
  transition: border-color 0.2s;
}

.task-input:focus {
  border-color: #4a90d9;
}

.add-btn {
  padding: 10px 18px;
  background-color: #4a90d9;
  color: white;
  font-size: 14px;
  font-weight: 600;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: background-color 0.2s;
}

.add-btn:hover {
  background-color: #357abd;
}

/* ===== TASK LIST ===== */
.task-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ===== TASK ITEM ===== */
.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f7f9fc;
  border: 1px solid #dce3ed;
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 14px;
  color: #2c3e50;
}

.task-text {
  flex: 1;
  margin-right: 10px;
  word-break: break-word;
}

.delete-btn {
  background: none;
  border: none;
  color: #e74c3c;
  font-size: 18px;
  cursor: pointer;
  line-height: 1;
  padding: 0 4px;
}

.delete-btn:hover {
  color: #c0392b;
}

/* ===== EMPTY STATE ===== */
.empty-msg {
  text-align: center;
  color: #aab4c0;
  font-size: 14px;
  padding: 16px 0;
}

/* ===== FOOTER ===== */
.footer {
  margin-top: 32px;
  font-size: 13px;
  color: #a0aab4;
  text-align: center;
}

.footer span {
  color: #4a90d9;
  font-weight: 600;
}
